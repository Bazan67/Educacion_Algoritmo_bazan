//Comparar el menor de dos numero reales
Algoritmo Estructura_Simple
	Definir num1,num2 Como Real;
	Escribir "ingresar el primer numero";
	leer num1;
	Escribir "ingresar el segundo numero";
	leer num2;
	//determinar el menor
	si num1 <num2 Entonces
		Escribir "El menor es: ", num1;
		si num2< num1 Entonces
			Escribir "el menor es: ", num2;
		FinSi
	FinSi
FinAlgoritmo
